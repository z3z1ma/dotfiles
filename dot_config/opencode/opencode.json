{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5-fast",
  "share": "disabled",
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "enabled_providers": [
    "openai",
    "github-copilot",
    "google-vertex",
    "amazon-bedrock"
  ],
  "autoupdate": true,
  "plugin": [
    "oh-my-opencode-slim@1.0.6",
    "opencode-openai-codex-auth@v.4.4.0",
    "opencode-wakatime@v1.3.7",
    "cc-safety-net@v0.8.2",
    "@plannotator/opencode@v0.19.6",
    "open-loom@0.1.5"
  ],
  "mcp": {},
  "experimental": {
    "aggressive_truncation": true,
    "openTelemetry": true
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-west-2",
        "profile": "ClaudeCode"
      }
    }
  }
}
