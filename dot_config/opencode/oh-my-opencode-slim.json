{
  "tmux": {
    "enabled": true
  },
  "agents": {
    "orchestrator": {
      "model": "openai/gpt-5.4",
      "variant": "low",
      "skills": ["*"]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "skills": []
    },
    "librarian": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "skills": []
    },
    "explorer": {
      "model": "openai/gpt-5.3-codex",
      "variant": "low",
      "skills": []
    },
    "designer": {
      "model": "google-vertex/gemini-3.1-pro-preview",
      "skills": ["playwright"]
    },
    "fixer": {
      "model": "amazon-bedrock/global.anthropic.claude-opus-4-6",
      "variant": "high",
      "skills": []
    },
    "council": {
      "master": { "model": "amazon-bedrock/global.anthropic.claude-sonnet-4-6" },
      "default_preset": "deep",
      "presets": {
        "quick": {
          "alpha": { "model": "openai/gpt-5.4-mini" }
        },
        "balanced": {
          "alpha": { "model": "openai/gpt-5.4-mini" },
          "beta":  { "model": "google-vertex/gemini-3.0-flash-preview" }
        },
        "deep": {
          "alpha": { "model": "openai/gpt-5.4-mini", "variant": "high" },
          "beta":  { "model": "google-vertex/gemini-3.1-pro-preview", "variant": "medium" },
          "gamma": { "model": "openai/gpt-5.3-codex", "variant": "high" },
          "delta": { "model": "amazon-bedrock/global.anthropic.claude-opus-4-6", "variant": "high" }
        }
      },
      "master_timeout": 300000,
      "councillors_timeout": 180000
    }
  }
}
