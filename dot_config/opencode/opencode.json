{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "share": "disabled",
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "enabled_providers": [
    "openai",
    "github-copilot",
    "google-vertex",
    "amazon-bedrock"
  ],
  "autoupdate": true,
  "plugin": [
    "oh-my-opencode-slim@0.9.0",
    "opencode-openai-codex-auth@v.4.4.0",
    "opencode-wakatime@v1.3.0",
    "cc-safety-net@v0.8.2",
    "@plannotator/opencode@v0.16.1"
  ],
  "mcp": {
    "call-me": {
      "enabled": false,
      "type": "local",
      "command": [
        "npm",
        "--prefix",
        "~/code_projects/personal/call-me/server",
        "run",
        "start"
      ],
      "timeout": 60000,
      "environment": {
        "CALLME_PHONE_PROVIDER": "telnyx"
      }
    },
    "serena": {
      "enabled": false,
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=claude-code",
        "--project-from-cwd",
        "--open-web-dashboard=false"
      ]
    }
  },
  "experimental": {
    "aggressive_truncation": true
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-west-2",
        "profile": "ClaudeCode"
      }
    }
  }
}
